# Local PostgreSQL connection string.
# Docker Compose default: postgres://nuchi:nuchi@localhost:5432/nuchi?sslmode=disable
DATABASE_URL=postgres://nuchi:nuchi@localhost:5432/nuchi?sslmode=disable

# Public base URL used by the frontend API client.
# Local Next.js default: http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3000

# Clerk keys for the current Next/Hono app.
# Replace these placeholders with real Clerk development keys before running `bun run build`.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_key_here
CLERK_SECRET_KEY=sk_test_your_key_here

# Optional server-side Clerk publishable key alias used by some local tooling/config.
# Keep this in sync with NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY when needed.
CLERK_PUBLISHABLE_KEY=pk_test_your_key_here

# Clerk route configuration for the current app.
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/

# Local SMTP settings. Docker Compose Mailpit defaults:
# SMTP: localhost:1025
# Web UI: http://localhost:8025
SMTP_HOST=localhost
SMTP_PORT=1025
MAILPIT_WEB_URL=http://localhost:8025

# Local app/runtime flags.
# APP_ENV is informational for local tooling.
APP_ENV=local

# Set to true only when intentionally running the seed script against local data.
ALLOW_DB_SEED=false

# Optional Hugging Face token for local tooling that may need it.
# Leave blank unless a workflow explicitly requires it.
HF_TOKEN=

# Go backend scaffold configuration.
# Defaults from backend/README.md: 0.0.0.0:8080
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8080
