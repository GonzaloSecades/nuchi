{"nodes": [{"id": "refreshapp_pr_summary_projectpolish", "label": "ProjectPolish PR Summary", "file_type": "document", "source_file": "refreshApp/pr summaries/project-polish-pr-summary.md", "source_location": "## Purpose", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "refreshapp_pr_summary_node_postgres", "label": "node-postgres Drizzle Runtime Switch", "file_type": "rationale", "source_file": "refreshApp/pr summaries/project-polish-pr-summary.md", "source_location": "Switched Drizzle runtime from Neon HTTP to node-postgres via db/connection.ts", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Switching from Neon HTTP adapter to node-postgres enables local Docker Postgres compatibility and richer connection pooling control."}, {"id": "refreshapp_pr_summary_tls_hardening", "label": "Remote Postgres TLS Certificate Verification", "file_type": "rationale", "source_file": "refreshApp/pr summaries/project-polish-pr-summary.md", "source_location": "Remote Postgres TLS now verifies certificates by default", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Default TLS verification prevents man-in-the-middle on remote DB connections; ALLOW_INSECURE_DATABASE_TLS=true allows opt-out for known self-signed scenarios."}, {"id": "refreshapp_pr_summary_hmr_pool_cache", "label": "globalThis Drizzle Pool HMR Cache", "file_type": "rationale", "source_file": "refreshApp/pr summaries/project-polish-pr-summary.md", "source_location": "App Drizzle pool creation uses a globalThis cache outside production to avoid Next.js dev HMR pool multiplication", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Next.js HMR reloads modules on each change; without a globalThis cache each reload would open a new pg.Pool, exhausting connections during development."}, {"id": "refreshapp_pr_summary_csv_chunking", "label": "CSV Import Chunke